# SpellCheck AI Backend - Configuración de Entorno
# Copia este archivo a .env y completa los valores

# ==========================================
# CONFIGURACIÓN DEL SERVIDOR
# ==========================================
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ==========================================
# CONFIGURACIÓN DE GOOGLE GENERATIVE AI
# ==========================================
# Obtén tu API Key de: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=tu_google_api_key_aqui
GOOGLE_MODEL=gemini-2.0-flash

# ==========================================
# CONFIGURACIÓN DE ARCHIVOS
# ==========================================
# Tamaño máximo de archivo en bytes (5MB = 5242880)
MAX_FILE_SIZE=5242880
# Tamaño máximo de texto a procesar en caracteres
MAX_TEXT_LENGTH=10000
# Directorio para guardar archivos temporales
UPLOAD_DIR=uploads

# ==========================================
# CONFIGURACIÓN DE SEGURIDAD
# ==========================================
# CORS: dominios permitidos (separados por comas)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,http://127.0.0.1:3000,http://127.0.0.1:5000

# Límite de rate limiting (requests por ventana de 15 minutos)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_MAX_UPLOADS=20
